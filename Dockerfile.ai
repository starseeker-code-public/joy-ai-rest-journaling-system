FROM python:3.13-slim

# ffmpeg: audio decoding for the Whisper transcription pipeline
RUN apt-get update && apt-get install -y --no-install-recommends ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY . .

# CPU-only torch first (~200MB vs ~2GB GPU build); subsequent install sees the
# requirement satisfied and won't pull the default GPU wheel.
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu

# Pull base deps + [ai] extras from pyproject.toml — single source of truth.
RUN pip install --no-cache-dir ".[ai]"

RUN useradd --create-home --shell /bin/bash app && chown -R app:app /app
USER app

# Pre-download the sentiment model so the worker doesn't pull it on first message
RUN python scripts/bootstrap_model.py

CMD ["python", "analysis_worker.py"]
