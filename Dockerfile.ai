FROM python:3.13-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    flask \
    python-dotenv \
    pymongo \
    argon2-cffi \
    pyjwt \
    pika \
    transformers

# CPU-only torch is ~200MB vs ~2GB for the default GPU build
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu

COPY . .

RUN useradd --create-home --shell /bin/bash app && chown -R app:app /app
USER app

# Pre-download the sentiment model so the worker doesn't pull it on first message
RUN python scripts/bootstrap_model.py

CMD ["python", "analysis_worker.py"]
