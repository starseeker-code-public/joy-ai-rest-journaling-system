# Flask
FLASK_ENV=development
DEBUG=True
PORT=5000
HOST=0.0.0.0
SECRET_KEY=dev-secret-key-change-me-in-production-12345

# MongoDB
MONGO_URL=mongodb://localhost:27017
MONGO_DB=joy

# RabbitMQ (default credentials are dev-only; rotate for production)
# 5673 is the host-published port of the compose broker (5672 inside the network)
RABBITMQ_URL=amqp://joy:joy@localhost:5673/
