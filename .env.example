# Flask
FLASK_ENV=development
DEBUG=True
PORT=5000
HOST=0.0.0.0
SECRET_KEY=dev-secret-key-change-me-in-production-12345

# MongoDB
MONGO_URL=mongodb://localhost:27017
MONGO_DB=joy

# OpenSearch (compose publishes it on 9200)
OPENSEARCH_URL=http://localhost:9200

# ClickHouse (compose publishes it on 8123)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123

# Redis (compose publishes it on 6380; 6379 inside the network)
REDIS_URL=redis://localhost:6380/0

# RabbitMQ (default credentials are dev-only; rotate for production)
# 5673 is the host-published port of the compose broker (5672 inside the network)
RABBITMQ_URL=amqp://joy:joy@localhost:5673/
