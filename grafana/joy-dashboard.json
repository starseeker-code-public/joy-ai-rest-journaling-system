{
  "title": "Joy — API & Business Metrics",
  "uid": "joy-overview",
  "schemaVersion": 39,
  "editable": true,
  "time": {"from": "now-6h", "to": "now"},
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by endpoint",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(joy_http_request_duration_seconds_count[5m]))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 latency by endpoint",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(joy_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error rate (5xx)",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(joy_http_request_duration_seconds_count{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Entries / habit checks / goals created",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "targets": [
        {"expr": "rate(joy_journal_entries_created_total[15m])", "legendFormat": "entries"},
        {"expr": "rate(joy_habit_checks_total[15m])", "legendFormat": "habit checks"},
        {"expr": "rate(joy_goals_created_total[15m])", "legendFormat": "goals"}
      ]
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Sentiment distribution (live entries)",
      "gridPos": {"h": 8, "w": 4, "x": 16, "y": 8},
      "targets": [
        {"expr": "joy_sentiment_entries", "legendFormat": "{{label}}"}
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Active users (7d)",
      "gridPos": {"h": 8, "w": 4, "x": 20, "y": 8},
      "targets": [
        {"expr": "joy_active_users_7d"}
      ]
    }
  ]
}
